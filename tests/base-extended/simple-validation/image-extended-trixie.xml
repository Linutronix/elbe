		<name>simple-validation-image</name>
		<version>1.0</version>
		<suite>trixie</suite>
		<buildtype>amd64</buildtype>

		<description>
			Image used to test ELBE features
		</description>

		<mirror>
			<primary_host>deb.debian.org</primary_host>
			<primary_path>/debian</primary_path>
			<primary_proto>http</primary_proto>
			<primary_key>
