	</project>

	<target>
		<hostname>validation-image</hostname>
		<domain>elbe-ci</domain>
		<passwd_hashed>!invalid</passwd_hashed>
		<console>ttyS0,115200</console>

                <debootstrap>
                        <type>base-image</type>
                </debootstrap>

		<images>
			<msdoshd>
				<name>sda.img</name>
				<size>1000MiB</size>
				<grub-install />
				<partition>
					<size>remain</size>
					<label>rfs</label>
				</partition>
			</msdoshd>
		</images>

		<fstab>
			<bylabel>
				<label>rfs</label>
				<mountpoint>/</mountpoint>
				<fs><type>ext4</type></fs>
			</bylabel>
		</fstab>

		<pkg-list>
			<pkg>wget</pkg>
		</pkg-list>

		<finetuning>
			<rm>var/cache/apt/archives/*.deb</rm>
			<command>rm -r /var/lib/apt/lists/</command>
		</finetuning>

		<project-finetuning>
			<set_packer packer="none">sda.img</set_packer>
		</project-finetuning>
	</target>
</ns0:RootFileSystem>
